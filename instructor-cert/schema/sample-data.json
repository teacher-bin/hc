  "_query_patterns": {
    "특정강사_전체기록": {
      "collection": "work_logs",
      "where": "instructor_id == '{instructor_id}'",
      "order_by": ["year ASC", "month ASC"],
      "use_case": "증명서 발급 시 전체 경력 목록 + 총시수 계산"
    },
    "특정강사_연도별": {
      "collection": "work_logs",
      "where": ["instructor_id == '{instructor_id}'", "year == {year}"],
      "use_case": "연도별 시수 합산 통계"
    },
    "특정강사_월별": {
      "collection": "work_logs",
      "where": [
        "instructor_id == '{instructor_id}'",
        "year == {year}",
        "month == {month}"
      ],
      "use_case": "특정 월 기록 단건 조회/편집"
    }
  },

  "_calculated_fields": {
    "_note": "아래 필드는 Firestore에 저장하지 않고 JavaScript에서 실시간 계산",
    "annual_total_hours": "work_logs에서 해당 instructor_id + year 필터링 후 hours 합산",
    "grand_total_hours": "work_logs에서 해당 instructor_id 전체 hours 합산",
    "activity_period": "work_logs의 첫 start_date ~ 마지막 end_date"
  }
