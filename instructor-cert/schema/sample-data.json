      "_document_id": "auto-generated (e.g. '{instructor_id}_{year}_{month:02d}'로 결정론적 ID 권장)",
      "_document_id_convention": "{instructor_id}_{YYYY}_{MM}  예: ABC123xyz_2025_03",
      "_composite_indexes": [
        "instructor_id + year (연도별 합산용)",
        "instructor_id + year + month (월별 조회용)"
